# xAI / SpaceXAI — server-side only (never expose to the browser)
# Get a key: https://console.x.ai
XAI_API_KEY=
# Optional model override (default: grok-4.5)
# XAI_MODEL=grok-4.5

# Supabase production identity + persistence (leave empty for local demo mode)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy projects may use NEXT_PUBLIC_SUPABASE_ANON_KEY instead.
